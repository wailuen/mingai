{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0",
  "title": "PO_ACKNOWLEDGEMENT",
  "description": "Seller agent acknowledges receipt and acceptance of a Purchase Order",
  "type": "object",
  "required": [
    "seller_agent_id",
    "po_transaction_id",
    "acknowledged_po_number",
    "status"
  ],
  "properties": {
    "seller_agent_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the acknowledging seller agent"
    },
    "po_transaction_id": {
      "type": "string",
      "description": "Transaction ID of the PO_PLACEMENT being acknowledged"
    },
    "acknowledged_po_number": {
      "type": "string",
      "minLength": 1,
      "description": "PO number being acknowledged"
    },
    "status": {
      "type": "string",
      "enum": ["accepted", "rejected", "partial"],
      "description": "Acknowledgement status"
    },
    "seller_reference": {
      "type": "string",
      "description": "Seller's internal reference number for this order"
    },
    "estimated_delivery_date": {
      "type": "string",
      "format": "date",
      "description": "Estimated delivery date from seller"
    },
    "rejection_reason": {
      "type": "string",
      "description": "Required when status is 'rejected'"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
