{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0",
  "title": "QUOTE_RESPONSE",
  "description": "Response to a Request for Quotation",
  "type": "object",
  "required": [
    "rfq_transaction_id",
    "responder_agent_id",
    "line_items",
    "total_amount",
    "currency"
  ],
  "properties": {
    "rfq_transaction_id": {
      "type": "string",
      "description": "Transaction ID of the original RFQ this responds to"
    },
    "responder_agent_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the agent providing the quote"
    },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "quantity", "unit_price"],
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "quantity": { "type": "number", "exclusiveMinimum": 0 },
          "unit_price": { "type": "number", "minimum": 0 },
          "sku": { "type": "string" }
        }
      },
      "description": "Quoted line items"
    },
    "total_amount": {
      "type": "number",
      "minimum": 0,
      "description": "Total quoted amount"
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "description": "ISO 4217 currency code"
    },
    "valid_until": {
      "type": "string",
      "format": "date-time",
      "description": "Quote validity expiry (ISO 8601)"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
