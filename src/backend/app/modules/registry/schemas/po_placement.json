{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0",
  "title": "PO_PLACEMENT",
  "description": "Purchase Order placement from buyer agent to seller agent",
  "type": "object",
  "required": [
    "buyer_agent_id",
    "seller_agent_id",
    "po_number",
    "line_items",
    "total_amount",
    "currency"
  ],
  "properties": {
    "buyer_agent_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the buying agent"
    },
    "seller_agent_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the selling agent"
    },
    "po_number": {
      "type": "string",
      "minLength": 1,
      "description": "Purchase order reference number"
    },
    "quote_transaction_id": {
      "type": "string",
      "description": "Transaction ID of the QUOTE_RESPONSE this PO is based on (optional)"
    },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "quantity", "unit_price"],
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "quantity": { "type": "number", "exclusiveMinimum": 0 },
          "unit_price": { "type": "number", "minimum": 0 },
          "sku": { "type": "string" }
        }
      }
    },
    "total_amount": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "delivery_address": {
      "type": "object",
      "description": "Delivery address for physical goods"
    },
    "requested_delivery_date": {
      "type": "string",
      "format": "date"
    },
    "payment_terms": {
      "type": "string",
      "description": "Payment terms (e.g. NET30)"
    }
  },
  "additionalProperties": true
}
