# Exclude secrets and dev-only files from Docker build context
.env
.env.*
!.env.example

# Test files (not needed in production image)
tests/
.pytest_cache/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# Editor and OS metadata
.git/
.gitignore
.DS_Store
*.swp
*.swo

# Development-only docs
README.md
*.md
