# mingai Backend - Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# NEVER commit .env to git - it contains secrets

# === Database ===
DATABASE_URL=postgresql+asyncpg://mingai:local_dev_only@localhost:5432/mingai
REDIS_URL=redis://localhost:6379/0

# === Cloud Provider ===
# Options: aws | azure | gcp | local
CLOUD_PROVIDER=local

# === AI Models (from .env ONLY - NEVER hardcode) ===
PRIMARY_MODEL=gpt-5.2-chat
INTENT_MODEL=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-small

# === Azure OpenAI (if CLOUD_PROVIDER=azure) ===
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://agentic-openai01.cognitiveservices.azure.com/
# AZURE_PLATFORM_OPENAI_API_KEY=
# AZURE_PLATFORM_OPENAI_ENDPOINT=https://eastus2.api.cognitive.microsoft.com/

# === Auth - JWT ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Auth0 (Phase 2+) ===
# Tenant domain: <your-tenant>.jp.auth0.com (or .us, .eu, .au based on region)
AUTH0_DOMAIN=
# API audience identifier (set when creating API in Auth0 dashboard)
AUTH0_AUDIENCE=
# Regular Web Application credentials (Next.js + FastAPI — NOT SPA)
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Management API application credentials (for SAML, JIT provisioning, user management)
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
# DEPRECATED: AUTH0_MANAGEMENT_API_TOKEN — do not use in production.
# The application auto-refreshes via Client Credentials grant (P3AUTH-021)
# using AUTH0_MANAGEMENT_CLIENT_ID / AUTH0_MANAGEMENT_CLIENT_SECRET above.
# AUTH0_MANAGEMENT_API_TOKEN=

# === Platform ===
FRONTEND_URL=http://localhost:3022
BACKEND_URL=http://localhost:8022
# MULTI_TENANT_ENABLED: true (default) — tenant_id resolved from JWT per request.
# Set to false for single-tenant deployments — forces all requests to tenant "default".
MULTI_TENANT_ENABLED=true
DEBUG=false

# === Screenshot Storage (API-014) ===
# Options: aws | azure | gcp | local
# CLOUD_PROVIDER is defined above; local mode also uses:
LOCAL_SCREENSHOT_DIR=/tmp/mingai_screenshots
# AWS S3 (if CLOUD_PROVIDER=aws):
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
# Azure Blob (if CLOUD_PROVIDER=azure):
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_KEY=
# AZURE_STORAGE_CONTAINER=
# GCS (if CLOUD_PROVIDER=gcp):
# GCS_BUCKET=


# === Platform Admin Bootstrap (INFRA-066) ===
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASS=
SEED_TENANT_NAME=

# === Logging ===
LOG_FORMAT=json

# === PA-013 Gross Margin (cost_summary_job) ===
# Daily plan revenue in USD per tenant. Set to 0 to disable gross margin tracking.
PLAN_REVENUE_STARTER_DAILY_USD=0
PLAN_REVENUE_PRO_DAILY_USD=0
PLAN_REVENUE_ENTERPRISE_DAILY_USD=0
INFRA_COST_PER_TENANT_DAILY_USD=0

# === PA-014 Azure Cost Management ===
# AZURE_SUBSCRIPTION_ID=
# AZURE_COST_MGMT_CLIENT_ID=
# AZURE_COST_MGMT_CLIENT_SECRET=
# AZURE_TENANT_ID=

# === Secrets Manager — HAR Agent Ed25519 Keys (DEF-007) ===
# When set, Ed25519 private keys are stored in Azure Key Vault instead of the DB.
# Leave empty to use LocalDBVaultClient (dev/test only — NOT secure for production).
# Requires: pip install azure-keyvault-secrets azure-identity
# Identity must have Key Vault Secrets Officer role on the target vault.
# Example: https://my-vault.vault.azure.net/
# AZURE_KEY_VAULT_URL=

# === JIT Provisioning — Internal Auth (P3AUTH-008) ===
# Shared secret for Auth0 Action → backend internal endpoints.
# Generate: openssl rand -hex 32
INTERNAL_SECRET_KEY=

# === P3AUTH-012 Migration Script ===
# Populate users.auth0_user_id for existing local users via Management API.
# Requires: AUTH0_DOMAIN, AUTH0_MANAGEMENT_CLIENT_ID, AUTH0_MANAGEMENT_CLIENT_SECRET, DATABASE_URL
#
# Usage:
#   python scripts/migrate_users_to_auth0.py [--dry-run] [--tenant-id <uuid>]
#
# Options:
#   --dry-run       Print changes without writing to the database
#   --tenant-id     Limit migration to one tenant (default: all tenants)
#   --batch-size    Auth0 API batch size; default 50
#
# The script is idempotent: rows where auth0_user_id IS NOT NULL are skipped.
# A CSV report (scripts/migration_report_<timestamp>.csv) is written on every run.

# === Optional Services ===
# SENDGRID_API_KEY=
# SENTRY_DSN=
# STRIPE_WEBHOOK_SECRET=
