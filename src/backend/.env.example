# mingai Backend - Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# NEVER commit .env to git - it contains secrets

# === Database ===
DATABASE_URL=postgresql+asyncpg://mingai:local_dev_only@localhost:5432/mingai
REDIS_URL=redis://localhost:6379/0

# === Cloud Provider ===
# Options: aws | azure | gcp | local
CLOUD_PROVIDER=local

# === AI Models (from .env ONLY - NEVER hardcode) ===
PRIMARY_MODEL=gpt-5.2-chat
INTENT_MODEL=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-small

# === Azure OpenAI (if CLOUD_PROVIDER=azure) ===
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://agentic-openai01.cognitiveservices.azure.com/
# AZURE_PLATFORM_OPENAI_API_KEY=
# AZURE_PLATFORM_OPENAI_ENDPOINT=https://eastus2.api.cognitive.microsoft.com/

# === Auth - JWT ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Auth0 (Phase 2+) ===
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=

# === Platform ===
FRONTEND_URL=http://localhost:3022
BACKEND_URL=http://localhost:8022
MULTI_TENANT_ENABLED=true
DEBUG=false

# === Screenshot Storage (API-014) ===
# Options: aws | azure | gcp | local
# CLOUD_PROVIDER is defined above; local mode also uses:
LOCAL_SCREENSHOT_DIR=/tmp/mingai_screenshots
# AWS S3 (if CLOUD_PROVIDER=aws):
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
# Azure Blob (if CLOUD_PROVIDER=azure):
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_KEY=
# AZURE_STORAGE_CONTAINER=
# GCS (if CLOUD_PROVIDER=gcp):
# GCS_BUCKET=


# === Platform Admin Bootstrap (INFRA-066) ===
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASS=
SEED_TENANT_NAME=

# === Logging ===
LOG_FORMAT=json

# === PA-013 Gross Margin (cost_summary_job) ===
# Daily plan revenue in USD per tenant. Set to 0 to disable gross margin tracking.
PLAN_REVENUE_STARTER_DAILY_USD=0
PLAN_REVENUE_PRO_DAILY_USD=0
PLAN_REVENUE_ENTERPRISE_DAILY_USD=0
INFRA_COST_PER_TENANT_DAILY_USD=0

# === PA-014 Azure Cost Management ===
# AZURE_SUBSCRIPTION_ID=
# AZURE_COST_MGMT_CLIENT_ID=
# AZURE_COST_MGMT_CLIENT_SECRET=
# AZURE_TENANT_ID=

# === Optional Services ===
# SENDGRID_API_KEY=
# SENTRY_DSN=
# STRIPE_WEBHOOK_SECRET=
